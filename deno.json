{
  "tasks": {
    "cache": "deno cache --node-modules-dir=auto src/main.ts tests/e2e.ts",
    "check": "deno check --node-modules-dir=auto src/main.ts",
    "compile": "deno compile -A --node-modules-dir=auto -o dist/pi-agent-daemon src/main.ts",
    "dev": "deno run -A src/main.ts serve --socket /tmp/pi-agent.sock",
    "e2e": "deno run --allow-net=127.0.0.1 --allow-read --allow-write=/tmp --allow-run=deno tests/e2e.ts",
    "fmt": "deno fmt",
    "lint": "deno lint",
    "prepare-release": "deno run --allow-read --allow-write scripts/prepare-release.ts"
  },
  "imports": {
    "@earendil-works/pi-coding-agent": "npm:@earendil-works/pi-coding-agent@0.79.2"
  },
  "fmt": {
    "lineWidth": 88,
    "indentWidth": 2
  }
}
